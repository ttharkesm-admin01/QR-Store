# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับของคุณ
#   cp .env.example .env

# สตริงเชื่อมต่อ PostgreSQL
# - ตอน deploy: ใช้ค่าจาก Neon / Vercel Postgres (มักลงท้าย ?sslmode=require)
# - ตอนรันในเครื่อง: เช่น postgresql://postgres@127.0.0.1:5432/qrstore
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# กุญแจลับสำหรับเซ็น cookie เซสชัน — ใส่ค่าสุ่มยาว ๆ และห้ามเปิดเผย
# สร้างได้ด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
